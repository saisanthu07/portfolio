# ─── Server ─────────────────────────────────────────────────
PORT=5001

# ─── MongoDB ─────────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/portfolio
# MongoDB Atlas (recommended for production):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/portfolio

# ─── CORS ────────────────────────────────────────────────────
# Your frontend URL (no trailing slash)
FRONTEND_URL=http://localhost:5173
# Production:
# FRONTEND_URL=https://your-cloudfront-domain.cloudfront.net

# ─── Email (Gmail) ──────────────────────────────────────────
# 1. Enable 2FA on your Google account
# 2. Go to: myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail"
SMTP_USER=saisanthoshborra@gmail.com
SMTP_PASS=your_gmail_app_password_here

# Where to receive contact notifications (defaults to SMTP_USER)
NOTIFY_EMAIL=saisanthoshborra@gmail.com

# ─── Admin ──────────────────────────────────────────────────
# Secret key to view form submissions via GET /api/contact/submissions
ADMIN_KEY=change_this_to_a_secure_random_string